{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config dist/main.js",
    "start:dev": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config ../../node_modules/@nestjs/cli/bin/nest.js start --watch",
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.prisma\"",
    "prisma:generate": "mkdir -p ./.prisma-engines-cache && PRISMA_ENGINES_CACHE_DIR=./.prisma-engines-cache DOTENV_CONFIG_PATH=../../.env node -r dotenv/config ../../node_modules/prisma/build/index.js generate",
    "prisma:migrate": "mkdir -p ./.prisma-engines-cache && PRISMA_ENGINES_CACHE_DIR=./.prisma-engines-cache DOTENV_CONFIG_PATH=../../.env node -r dotenv/config ../../node_modules/prisma/build/index.js migrate dev",
    "prisma:status": "mkdir -p ./.prisma-engines-cache && PRISMA_ENGINES_CACHE_DIR=./.prisma-engines-cache DOTENV_CONFIG_PATH=../../.env node -r dotenv/config ../../node_modules/prisma/build/index.js migrate status"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^22.10.1",
    "prisma": "^6.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
