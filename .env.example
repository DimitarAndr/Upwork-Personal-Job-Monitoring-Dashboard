# API
API_PORT=4000
INTAKE_WEBHOOK_KEY=change-me-for-n8n

# n8n (local Docker)
N8N_PORT=5678
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string
GENERIC_TIMEZONE=UTC

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Postgres
# Docker default from docker-compose.yml:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/proposal_intel?schema=public
#
# Existing local/remote PostgreSQL:
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/proposal_intel?schema=public

# Optional: Codex PostgreSQL MCP setup reads this value first.
# If omitted, the project helper falls back to DATABASE_URL.
# POSTGRES_MCP_URL=postgresql://postgres:your_password@localhost:5432/proposal_intel?schema=public
